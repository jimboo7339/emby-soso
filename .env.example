# Application
APP_PORT=8080
LOG_LEVEL=info
SCHEDULER_ENABLED=true
WEB_WORKERS=2

# Login (change defaults before exposing to the internet)
AUTH_ENABLED=true
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me
AUTH_SECRET_KEY=change-me-use-a-long-random-string-in-production
AUTH_TOKEN_EXPIRE_HOURS=168
AUTH_COOKIE_SECURE=false

# Docker image (Release 构建产物，本地开发可改为 emby-soso:latest)
EMBY_SOSO_IMAGE=ghcr.io/jimboo7339/emby-soso:latest

# Database (default: bundled PostgreSQL via compose)
DATABASE_URL=postgresql+psycopg://emby:emby@postgres:5432/emby_soso

# MySQL example (use with: docker compose -f docker-compose.yml -f docker-compose.mysql.yml up -d)
# DATABASE_URL=mysql+pymysql://emby:emby@mysql:3306/emby_soso?charset=utf8mb4

# External database example (app only)
# DATABASE_URL=postgresql+psycopg://user:change-me@db.example.com:5432/emby_soso

# Redis (optional — leave empty for standalone mode)
REDIS_URL=
REDIS_ENABLED=auto

# TMDB
TMDB_API_KEY=
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_LANGUAGE=zh-CN

# Media paths (host paths mapped in docker-compose)
SOURCE_VOLUME=./data/source
LIBRARY_VOLUME=./data/library
DATA_SOURCE_ROOT=/data/source
DATA_LIBRARY_ROOT=/data/library

# PostgreSQL (compose bundled)
POSTGRES_USER=emby
POSTGRES_PASSWORD=emby
POSTGRES_DB=emby_soso

# MySQL (compose profile mysql)
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=emby_soso
MYSQL_USER=emby
MYSQL_PASSWORD=emby
