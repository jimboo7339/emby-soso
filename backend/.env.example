# 复制为 backend/.env 后按需修改（勿提交 .env 到 Git）

# 本地开发可用 SQLite；生产建议 PostgreSQL / MySQL
DATABASE_URL=sqlite:///./data/emby_soso.db

# 媒体目录（本地开发用相对路径；Docker 内通常为 /data/source、/data/library）
DATA_SOURCE_ROOT=./data/source
DATA_LIBRARY_ROOT=./data/library

# TMDB（可在 Web 系统设置中配置，此处为启动默认值）
TMDB_API_KEY=
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_LANGUAGE=zh-CN

SCHEDULER_ENABLED=true
LOG_LEVEL=info
APP_PORT=8080
