# ========== 宿主机部署配置（docker-compose.host.yml）==========
# 复制为 .env 后修改：
#   cp .env.host.example .env

APP_PORT=8080
LOG_LEVEL=info
SCHEDULER_ENABLED=true
WEB_WORKERS=2

# ---------- 登录认证（务必修改默认密码）----------
AUTH_ENABLED=true
AUTH_USERNAME=admin
AUTH_PASSWORD=请替换为强密码
AUTH_SECRET_KEY=请替换为随机长字符串
AUTH_TOKEN_EXPIRE_HOURS=168
AUTH_COOKIE_SECURE=false

EMBY_SOSO_IMAGE=ghcr.io/jimboo7339/emby-soso:latest

# ---------- PostgreSQL（宿主机已有，先运行 scripts/init-postgres.sh）----------
# 容器内通过 host.docker.internal 访问宿主机
# 将 emby_soso / 你的密码 / 5432 替换为脚本输出值
DATABASE_URL=postgresql+psycopg://emby_soso:请替换为强密码@host.docker.internal:5432/emby_soso

# 若 PG 监听在其他 IP/端口，改为实际地址，例如：
# DATABASE_URL=postgresql+psycopg://emby_soso:密码@192.168.1.100:5432/emby_soso

# ---------- Redis（宿主机已有，无密码）----------
REDIS_URL=redis://host.docker.internal:6379/0
REDIS_ENABLED=true

# 若 Redis 在其他地址：
# REDIS_URL=redis://192.168.1.100:6379/0

# ---------- TMDB ----------
TMDB_API_KEY=
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_LANGUAGE=zh-CN

# ---------- 媒体目录（宿主机绝对路径）----------
# 示例 Linux：
SOURCE_VOLUME=/volume1/media/source
LIBRARY_VOLUME=/volume1/media/library

# 示例 Windows（Docker Desktop）：
# SOURCE_VOLUME=F:/media/source
# LIBRARY_VOLUME=F:/media/library

DATA_SOURCE_ROOT=/data/source
DATA_LIBRARY_ROOT=/data/library

# ---------- init-postgres.sh 可选变量（在宿主机执行脚本时用）----------
# PG_SUPERUSER=postgres
# PG_HOST=127.0.0.1
# PG_PORT=5432
# DB_NAME=emby_soso
# DB_USER=emby_soso
# DB_PASSWORD=请设置强密码
